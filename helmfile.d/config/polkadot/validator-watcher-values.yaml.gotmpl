image:
  repo: ironoa/polkadot-watcher
  tag: tmp-2

config:
  endpoint: "wss://polkadot-rpc.publicnode.com/"
  validators: {{ if eq (len .Environment.Values.validatorsPolkadot) 0 }} [] {{ end }}
  {{- range $index, $value := .Environment.Values.validatorsPolkadot }}
  - name: {{ $value.name }}
    address: {{ $value.stashAccount }}
  {{- end }}

prometheusRules:
  enabled: true
  origin: monitoring
  offlineRisk: true
  producerStall: false
